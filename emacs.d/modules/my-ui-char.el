;; ---- Apply -----------------------------------------------------------------

(defun my/char-width-apply-ranges (ranges)
  "Apply RANGES (list of (LO HI WIDTH)) to `char-width-table'."
  (pcase-dolist (`(,lo ,hi ,w) ranges)
    (set-char-table-range char-width-table (cons lo hi) w)))

(defun my/char-width-setup (&optional frame)
  "Match `char-width-table' to how FRAME actually counts columns.
GUI uses the default font's glyph advances; a terminal uses wcwidth
ambiguous-narrow.  The default font is only settled after my-ui-face applies
it, so this runs from `after-init-hook' / `after-make-frame-functions'."
  (if (display-graphic-p frame)
      ;; GUI: font-specific correction; add a when-block per extra font.
      (let ((family (and (boundp 'my/font-default) (plist-get my/font-default :family))))
        (when (equal family "PlemolJP NF")
          (my/char-width-apply-ranges my/plemoljp-gui-char-width-ranges)
          ;; Box-drawing U+2500-257F is baked half-width into our PlemolJP NF
          ;; build (Console NF glyphs merged in via local/bin/build-plemoljp-nf),
          ;; so set char-width to 1 to match.  We cannot reroute it with
          ;; set-fontset-font here: on macOS the face's own :family covers
          ;; box-drawing and wins over the fallback fontset.
          (set-char-table-range char-width-table (cons #x2500 #x257F) 1)))
    ;; TTY: terminal counts by wcwidth ambiguous-narrow (font independent).
    (my/char-width-apply-ranges my/char-width-ambig-narrow-ranges)))

(add-hook 'after-init-hook #'my/char-width-setup)
(add-hook 'after-make-frame-functions #'my/char-width-setup)

(provide 'my-ui-char)
