;;; my-ui-char.el --- character width settings -*- lexical-binding: t; -*-

;;; Commentary:
;; Align char-width with whatever actually decides the column count, which
;; differs by environment:
;;
;; - In a GUI, Emacs draws the glyphs itself, so char-width is matched to the
;;   glyph advances of the default font in use (font specific).  Each font gets
;;   its own (when (equal family "...") ...) block; add new fonts there.
;;
;; - In a terminal, the terminal emulator counts columns via wcwidth
;;   (ambiguous-narrow), so ambiguous characters are set to width 1 (font
;;   independent; matches Ghostty / mintty Charwidth=ambig-narrow / tmux).
;;
;; The font-specific char-width data (the defconsts below) is regenerated by
;; local/bin/gen-plemoljp-char-width (it replaces the text between the markers).

;;; Code:

