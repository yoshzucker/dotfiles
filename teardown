#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

################################################################################
# Help / usage
################################################################################
usage() {
  cat <<EOF
Usage:
  $0 unlink
  -h, --help         Show this help message
EOF
  exit 1
}

################################################################################
# Option parsing
################################################################################
while getopts hn-: opt; do
  case $opt in
    h) usage ;;
    -)
      case "$OPTARG" in
        help) usage ;;
        *) echo "Unknown option --$OPTARG"; usage ;;
      esac
      ;;
    \?) echo "Invalid option: -$OPTARG" >&2; usage ;;
  esac
done
shift $((OPTIND - 1))

################################################################################
# Remove symbolic links
################################################################################
unlink_dotfiles() {
  echo "Unlinking dotfiles..."

  # Remove dotfile symlinks directly under $HOME
  find "$HOME" -maxdepth 1 -type l -name ".*" -print -exec rm -f {} +

  # Remove symlinks under .config, .local (incl. .local/bin contents), .emacs.d
  # New model: ~/.local/bin is a real dir. We clean managed symlinks inside it.
  # Also handle the case where ~/.local/bin itself is still an old whole-directory symlink.
  for dir in "$HOME/.config" "$HOME/.local" "$HOME/.local/bin" "$HOME/.emacs.d"; do
    if [ -L "$dir" ] || [ -d "$dir" ]; then
      find "$dir" -maxdepth 1 -type l -print -exec rm -f {} +
    fi
  done

  # If ~/.local/bin itself is still a symlink (old style), remove it too
  if [ -L "$HOME/.local/bin" ]; then
    rm -f "$HOME/.local/bin"
  fi

  echo "Finished unlinking."
}

################################################################################
# Main
################################################################################

if [ "$#" -eq 0 ]; then
  usage
fi

case "$1" in
  unlink)
    unlink_dotfiles
    ;;
  *)
    echo "Unknown command: $1" >&2
    usage
    ;;
esac
