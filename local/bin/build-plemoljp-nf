#!/usr/bin/env bash

set -euo pipefail
IFS=$'\n\t'

# build-plemoljp-nf — build a single "PlemolJP NF" font: NON-Console PlemolJP
# (East-Asian ambiguous glyphs valued in Japanese prose stay FULL width:
# enclosed alphanumerics ①-⑳, math ∀ ∃ ∈ ∉, misc symbols ★ ⚠ ☑ ☒) carrying
# the Nerd Font icons taken from the official "PlemolJP Console NF".
# Ambiguous-width UI-decoration blocks (arrows → ← ⇒, box-drawing ─ │ ┌ ┐,
# block elements ▀ ▄ █ ░ ▒ ▓, geometric shapes ▶ ▼ ■ ● ○ ◆, dingbats ✓ ✗ ❯,
# misc symbols and arrows ⬆ ⬇ ⭐) are OVERRIDDEN with Console NF's HALF-width
# glyphs so modern Emacs UI packages (agent-shell expand markers, magit,
# transient, mode-line) that pad columns assuming these are single-cell keep
# their alignment intact.
#
# Why: the official Nerd Fonts build of PlemolJP (PlemolJP_NF release) ships
# Console variants only, which draw ambiguous-width glyphs (→ ★ ※ …) at half
# width. Patching the non-Console PlemolJP directly with nerd-fonts' font-patcher
# does not reproduce correct single-cell icon/powerline sizing for this
# dual-width CJK font. Instead we copy the already-correct Nerd glyphs (PUA) out
# of PlemolJP Console NF into the non-Console PlemolJP, plus overlay a curated
# set of UI-decoration ambiguous blocks with Console NF's half-width glyphs.
# Both share the same em and design, so the icons drop in unchanged.
#
# Result family: "PlemolJP NF"  (styles: Regular / Bold / Italic / BoldItalic)
#
# Prerequisite: fontforge (macOS: brew install fontforge).
# Installs into ~/Library/Fonts (macOS) or ~/.local/share/fonts (Linux). On
# Windows/MSYS2 the ttf are only built into "$WORKDIR/dist" (bootstrap.ps1
# registers them for the user). Override WORKDIR to control the build location.

PLEMOLJP_VERSION="${PLEMOLJP_VERSION:-3.0.0}"
STYLES=(Regular Bold Italic BoldItalic)

command -v fontforge >/dev/null || { echo "error: fontforge not found (brew install fontforge)" >&2; exit 1; }

WORKDIR="${WORKDIR:-$(mktemp -d "${TMPDIR:-/tmp}/plemoljp-nf.XXXXXX")}"
DISTDIR="$WORKDIR/dist"
mkdir -p "$DISTDIR"
echo ">> work dir: $WORKDIR"

base_url="https://github.com/yuru7/PlemolJP/releases/download/v${PLEMOLJP_VERSION}"

# Non-console PlemolJP (source of full-width glyphs) is not normally installed,
# so always fetch it.
echo ">> downloading PlemolJP (non-NF) v${PLEMOLJP_VERSION}"
curl -fsSL -o "$WORKDIR/PlemolJP.zip" "$base_url/PlemolJP_v${PLEMOLJP_VERSION}.zip"
unzip -oq "$WORKDIR/PlemolJP.zip" -d "$WORKDIR/src"
base_dir="$WORKDIR/src/PlemolJP_v${PLEMOLJP_VERSION}/PlemolJP"

# Nerd glyph source = PlemolJP Console NF. Reuse an installed copy when present
# (e.g. the font-plemol-jp-nf cask on macOS) to avoid a large extra download.
sym_dir=""
for d in "$HOME/Library/Fonts" "$HOME/.local/share/fonts" "$HOME/.fonts" "/Library/Fonts"; do
  if [ -f "$d/PlemolJPConsoleNF-Regular.ttf" ]; then sym_dir="$d"; break; fi
done
if [ -z "$sym_dir" ]; then
  echo ">> downloading PlemolJP_NF (Console NF source) v${PLEMOLJP_VERSION}"
  curl -fsSL -o "$WORKDIR/PlemolJP_NF.zip" "$base_url/PlemolJP_NF_v${PLEMOLJP_VERSION}.zip"
  unzip -oq "$WORKDIR/PlemolJP_NF.zip" -d "$WORKDIR/nf"
  sym_dir="$WORKDIR/nf/PlemolJP_NF_v${PLEMOLJP_VERSION}/PlemolJPConsole_NF"
fi
echo ">> nerd glyph source: $sym_dir"

cat > "$WORKDIR/merge.py" <<'PY'
import fontforge, psMat, struct, sys
base_path, sym_path, out_path = sys.argv[1], sys.argv[2], sys.argv[3]
NEWFAM = "PlemolJP NF"

# --- OS/2 xAvgCharWidth preservation -----------------------------------------
# fontforge.generate() RECOMPUTES OS/2.xAvgCharWidth by averaging glyph advances.
# Our base is the non-Console PlemolJP, whose ~539 East-Asian *ambiguous* glyphs
# are full width (1056), so the recomputed average balloons (~822 vs the source's
# 528 = ASCII half-width). Windows GDI / Emacs use xAvgCharWidth to size the text
# cell: an inflated value makes frame-char-width too large, so ASCII underfills
# its column (frame goes wide) and CJK glyphs scale up ~1.5x. (macOS / Core Text
# ignores xAvgCharWidth for cell metrics, which is why only Windows breaks.)
# fontforge exposes no setter for this field, so we read the source's value and
# patch the generated binary back to it, fixing the affected checksums.

def _sum32(data):
    if len(data) % 4:
        data = data + b"\x00" * (4 - len(data) % 4)
    s = 0
    for i in range(0, len(data), 4):
        s = (s + struct.unpack(">I", data[i:i+4])[0]) & 0xFFFFFFFF
    return s

def _read_xavg(path):
    d = open(path, "rb").read()
    for i in range(struct.unpack(">H", d[4:6])[0]):
        e = 12 + 16 * i
        if d[e:e+4] == b"OS/2":
            o = struct.unpack(">I", d[e+8:e+12])[0]
            return struct.unpack(">h", d[o+2:o+4])[0]
    return None

def _set_xavg(path, value):
    d = bytearray(open(path, "rb").read())
    os2_e = os2_o = os2_l = head_o = None
    for i in range(struct.unpack(">H", d[4:6])[0]):
        e = 12 + 16 * i
        tag = bytes(d[e:e+4])
        off = struct.unpack(">I", d[e+8:e+12])[0]
        ln  = struct.unpack(">I", d[e+12:e+16])[0]
        if tag == b"OS/2":  os2_e, os2_o, os2_l = e, off, ln
        elif tag == b"head": head_o = off
    if os2_o is None or head_o is None:
        return
    struct.pack_into(">h", d, os2_o + 2, value)                 # xAvgCharWidth
    struct.pack_into(">I", d, os2_e + 4, _sum32(bytes(d[os2_o:os2_o+os2_l])))  # OS/2 checksum
    struct.pack_into(">I", d, head_o + 8, 0)                    # zero checkSumAdjustment
    struct.pack_into(">I", d, head_o + 8, (0xB1B0AFBA - _sum32(bytes(d))) & 0xFFFFFFFF)
    open(path, "wb").write(d)

src_xavg = _read_xavg(base_path)   # = 528 for PlemolJP; preserve (scaled by S below)
# -----------------------------------------------------------------------------

base = fontforge.open(base_path)   # non-console PlemolJP (full-width arrows, no nerd)
sym  = fontforge.open(sym_path)    # PlemolJP Console NF (perfect single-cell nerd glyphs)
assert base.em == sym.em
base.encoding = 'UnicodeFull'; sym.encoding = 'UnicodeFull'
copied = 0
for g in sym.glyphs():
    u = g.unicode
    if u is None or u < 0xE000:      # only PUA / nerd glyph area
        continue
    if u in base:                     # keep base's native glyphs (e.g. powerline E0A0-E0B3)
        continue
    sym.selection.none(); sym.selection.select(("unicode",), u); sym.copy()
    base.selection.none(); base.selection.select(("unicode",), u); base.paste()
    base[u].width = g.width
    copied += 1

# Override ambiguous-width UI-decoration blocks with Console NF's HALF-width
# glyphs. Modern Emacs UI packages (agent-shell expand markers, magit,
# transient, mode-line) pad on the assumption these render in a single cell;
# keeping them full width breaks column alignment (e.g. an "▶ " expand prefix
# vs an empty "  " prefix on the same visual column).
# In the Emacs GUI a face's :family (PlemolJP NF) covers these ranges, so a
# per-range set-fontset-font override to the Console font is ignored on macOS;
# baking the half-width glyphs into the font itself is what makes them render
# single-cell (char-width follows via emacs.d/modules/my-ui-char.el, whose GUI
# map is regenerated from font glyph advances by local/bin/gen-plemoljp-char-width).
#
# Excluded from this list on purpose (Japanese prose still expects full width):
#   U+2160-217F Roman Numerals           (Ⅰ Ⅱ Ⅲ)
#   U+2200-22FF Mathematical Operators   (∀ ∃ ∈ ∉ ≠ ≦ ≧ ∴ ∵)
#   U+2460-24FF Enclosed Alphanumerics   (① ⑳ ㊤ ㊥ ㊦)
#   U+2600-26FF Miscellaneous Symbols    (☑ ☒ ☐ ★ ⚠ ☂ ♠ ♣ ♥ ♦) — used mostly
#     as content in Org export / docstrings, rarely as column-aligned UI markers
HALF_WIDTH_OVERRIDES = [
    (0x2190, 0x21FF),  # Arrows                          (→ ← ↑ ↓ ↔ ⇒ ⇔)
    (0x2500, 0x257F),  # Box Drawing                     (─ │ ┌ ┐ └ ┘ ├ ┼)
    (0x2580, 0x259F),  # Block Elements                  (▀ ▄ █ ░ ▒ ▓)
    (0x25A0, 0x25FF),  # Geometric Shapes                (▶ ▼ ◀ ▲ ■ ● ○ ◆)
    (0x2700, 0x27BF),  # Dingbats                        (✓ ✗ ✔ ✘ ❯ ❮)
    (0x2B00, 0x2BFF),  # Miscellaneous Symbols and Arrows (⬆ ⬇ ⬅ ➡ ⭐)
]
halved = 0
for lo, hi in HALF_WIDTH_OVERRIDES:
    for u in range(lo, hi + 1):
        if u in sym and u in base:
            sym.selection.none(); sym.selection.select(("unicode",), u); sym.copy()
            base.selection.none(); base.selection.select(("unicode",), u); base.paste()
            base[u].width = sym[u].width
            halved += 1
def rename(val, key):
    if not isinstance(val, str) or "PlemolJP" not in val:
        return val
    if key in ("PostScriptName", "UniqueID"):
        return val.replace("PlemolJP", "PlemolJPNF")
    return val.replace("PlemolJP", NEWFAM)
orig_sfnt = list(base.sfnt_names)          # capture BEFORE touching name props
orig_fontname = base.fontname
orig_fullname = base.fullname
base.familyname = NEWFAM
base.fontname   = orig_fontname.replace("PlemolJP", "PlemolJPNF")
base.fullname   = orig_fullname.replace("PlemolJP", NEWFAM)
base.sfnt_names = tuple((lang, key, rename(val, key)) for (lang, key, val) in orig_sfnt)
# --- Advance-width normalization: full-width cell == 1 em --------------------
# PlemolJP's advances are exactly 2:1 (528 half / 1056 full) but sit on a 1000
# em, so the full-width cell is 1.056 em (not a whole em). Integer pixel
# rounding then breaks the 2:1 at render time (e.g. at 14 px: round(0.528*14)=7
# ASCII but round(1.056*14)=15 full, and 2*7 != 15), drifting ASCII vs CJK
# columns in the Emacs GUI. Rescale outlines by S = em/FULL so full advance =
# em (1000) and half advance = em/2 (500): 2:1 stays exact and CJK pixel cell
# is an integer multiple of ASCII cell at every even pixel size. Only outlines
# are scaled here; line-box metrics are set explicitly below (independent of
# advance width). font.ascent/descent are left untouched (they always equal em
# by fontforge's contract).
FULL = base[0x3042].width                 # 'あ' full-width advance (1056)
S = base.em / float(FULL)                 # 1000/1056; 1056->1000, 528->500 exactly
if abs(S - 1.0) > 1e-9:
    w0 = {g.glyphname: (g.width, g.vwidth) for g in base.glyphs()}
    base.selection.all()
    base.transform(psMat.scale(S))        # scales outlines
    for g in base.glyphs():
        ow, ovw = w0[g.glyphname]
        g.width  = int(round(ow  * S))    # overwrite -> exact, double-scale-safe
        g.vwidth = int(round(ovw * S))
    if src_xavg is not None:
        src_xavg = int(round(src_xavg * S))   # 528 -> 500, restored after generate

# --- Line-box: intent-driven line-height from Nerd tile + JP glyph extents ---
# Chosen deductively from the extents of the glyphs the font actually contains
# after the outline S-scale above, not inherited from the upstream default.
# Measured constraints (font units, post-S outlines):
#   * Powerline slant peak      (U+E0BA lower-L triangle): ymax =  890
#     Setting winAsc = 890 lets the slant fill the row edge-to-edge; a lower
#     winAsc would leak the face bg through the slant tip (this was the
#     Windows Emacs tab-bar hairline observed with an earlier 850/-200 box).
#     Powerline dividers at ymax = 859 and slants at 890 vary within the
#     Nerd Font design; the tile-glyph rescale below normalises everything
#     to LINE_ASC exactly.
#   * kana handakuten peak      (widest across hiragana/katakana): ず = 835
#     55-unit clearance above -- comfortable for AA and hinting.
#   * Latin lowercase descender (deepest ASCII descender):         g  = -196
#     Sets winDesc >= 196; 210 gives 14-unit clearance.
# Total = 890 + 210 = 1100 = 1.10 em -- "1 em + 1 wari (10%) leading", the
# tight-but-safe line-height typical for JP-oriented monospace code fonts.
# Rare stacked Latin Extended diacritics (Ǻ = 1028; combining marks in
# U+03xx below -238) exceed this box; accepted as an intentional trade-off
# for a JP-first, code-oriented design that keeps the row compact.
# Reference: upstream 950/-225 = 1.175 em (comfortable but loose for code).
LINE_ASC  = 890
LINE_DESC = 210

# --- Rescale tile-shape glyphs so they exactly fill the line-box -------------
# Nerd/Console tile glyphs (Powerline slants, box-drawing verticals, block
# elements) were designed against their own source line-box.  In our 890/-210
# box the outlines fall short of the row edge (e.g. Console NF Powerline slant
# reaches ymax = 890 but ymin = -202, so an 8-unit strip of face bg leaks
# below every slant tab), producing sub-pixel hairlines at row boundaries.
# Selection uses a two-stage filter:
#   (1) whitelist by Unicode range -- only ranges of "tile shape" glyphs.
#       Excludes all text glyphs (kana, kanji, Latin, punctuation, IPA) at
#       range level so readable characters are never distorted, even when
#       their descenders happen to overshoot the em box.
#   (2) within the whitelist, require BOTH edges of the outline to sit near
#       the source line-box (ymax > 800 AND ymin < -180).  This captures
#       "full-tile" shapes (│ ┃ ┼ █ ░ Powerline slants) that need to fill
#       the row edge-to-edge.  Half-tile shapes (corners like ┌, upper/lower
#       half blocks like ▀ ▄) are intentionally skipped: proportional Y
#       rescale would shift their mid-em ink (a corner's horizontal stroke
#       would move away from mid-em), breaking alignment with adjacent
#       single-line ─; leaving them intact lets their natural bottom (or
#       top) overshoot get clipped at the row boundary, which visually tiles
#       seamlessly with adjacent full-tile verticals.
TILE_RANGES = [
    (0x2500, 0x257F),  # Box Drawing
    (0x2580, 0x259F),  # Block Elements
    (0xE0A0, 0xE0D4),  # Powerline (branch/LN markers + separators + slants)
]
rescaled = 0
for lo, hi in TILE_RANGES:
    for u in range(lo, hi + 1):
        if u not in base:
            continue
        g = base[u]
        b = g.boundingBox()               # (xmin, ymin, xmax, ymax)
        if not b:
            continue
        _, y_lo, _, y_hi = b
        if not (y_hi > 800 and y_lo < -180):
            continue                       # not full-tile; leave outline alone
        if abs(y_hi - LINE_ASC) < 0.5 and abs(y_lo - (-LINE_DESC)) < 0.5:
            continue                       # already at target
        sy = (LINE_ASC - (-LINE_DESC)) / float(y_hi - y_lo)
        m = psMat.compose(
                psMat.compose(psMat.translate(0.0, -y_lo),
                              psMat.scale(1.0, sy)),
                psMat.translate(0.0, -LINE_DESC))
        g.transform(m)
        rescaled += 1

base.os2_winascent   = LINE_ASC
base.os2_windescent  = LINE_DESC
base.os2_typoascent  = LINE_ASC
base.os2_typodescent = -LINE_DESC
base.os2_typolinegap = 0
base.hhea_ascent     = LINE_ASC
base.hhea_descent    = -LINE_DESC
base.hhea_linegap    = 0

print("  %s -> %d nerd, %d half-width, %d tile-rescaled" % (out_path.split('/')[-1], copied, halved, rescaled))
base.generate(out_path)
# Restore OS/2.xAvgCharWidth to the source value (fontforge inflated it on generate).
if src_xavg is not None:
    _set_xavg(out_path, src_xavg)
PY

echo ">> merging styles: ${STYLES[*]}"
for s in "${STYLES[@]}"; do
  fontforge -lang=py -script "$WORKDIR/merge.py" \
    "$base_dir/PlemolJP-$s.ttf" "$sym_dir/PlemolJPConsoleNF-$s.ttf" \
    "$DISTDIR/PlemolJPNF-$s.ttf" 2>&1 | grep -E '  PlemolJPNF-' || true
done

case "$(uname -s)" in
  Darwin) dest="$HOME/Library/Fonts" ;;
  Linux)  dest="$HOME/.local/share/fonts"; mkdir -p "$dest" ;;
  *)      dest="" ;;   # Windows/MSYS2: bootstrap.ps1 registers from $DISTDIR
esac
if [ -n "$dest" ]; then
  echo ">> installing into $dest"
  cp -f "$DISTDIR"/*.ttf "$dest"/
  command -v fc-cache >/dev/null && fc-cache -f "$dest" >/dev/null 2>&1 || true
else
  echo ">> built fonts in $DISTDIR (install them manually / via bootstrap.ps1)"
fi

echo ">> done. family: \"PlemolJP NF\""
ls -1 "$DISTDIR"/*.ttf
