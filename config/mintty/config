# wsltty config

# Looks
Transparency=0
CursorType=block
CursorBlinks=no

# Text
Font=PlemolJP Console NF
FontHeight=13

BoldAsFont=no
BoldAsColour=no
DimAsFont=no

Locale=ja_JP
Charset=UTF-8

# Keys
ClipShortcuts=yes
WindowShortcuts=no
AltFnShortcuts=no
ZoomShortcuts=no


# Mouse


# Selection


# Window
Columns=80
Rows=25

Scrollbar=none
ScrollMod=off
# When running tmux the wheel is handed to tmux, so mintty's own scrollback is
# bypassed; the settings below only apply to bare mintty (e.g. right after
# login, before attaching tmux). Match the tmux wheel feel (1 line/notch);
# mintty's default is taken from the Windows mouse setting (~3). ScrollbackLines
# is capped by MaxScrollbackLines, so raise both together.
LinesPerMouseWheelNotch=1
ScrollbackLines=50000
MaxScrollbackLines=50000

Language=ja

# Terminal
Term=xterm-256color
XTermModifyOtherKeys=1
AllowBlinking=no

BellType=0

# wsltty config ends here
ComposeKey=off
SwitchShortcuts=no
