# wsltty config

# Looks
Transparency=0
CursorType=block
CursorBlinks=no

# Text
Font=FirgeNerd Console
FontHeight=13

BoldAsFont=no
BoldAsColour=no
DimAsFont=no

Locale=ja_JP
Charset=UTF-8

# Keys
ClipShortcuts=yes
WindowShortcuts=no
AltFnShortcuts=no
ZoomShortcuts=no


# Mouse


# Selection


# Window
Columns=80
Rows=25

Scrollbar=none
ScrollMod=off

Language=ja

# Terminal
Term=xterm-256color
XTermModifyOtherKeys=1
AllowBlinking=no

BellType=0

# wsltty config ends here
ComposeKey=off
SwitchShortcuts=no
