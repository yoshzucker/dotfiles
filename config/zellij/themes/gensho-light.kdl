// gensho-light — derived from gensho-theme.el `dry` variant.
// "Dry / washed-stone" is gensho's lighter mode (still a muted dark tone,
// not paper-white). Hue values match gensho-dark; only the mono ramp shifts.
themes {
    gensho-light {
        fg      162 166 167  // mono7
        bg       60  61  62  // mono0
        black    73  75  75  // mono1
        red     212 100 127
        green    89 150  94
        yellow  162 131  90
        blue     99 140 180
        magenta 203  99 174
        cyan     95 145 150
        white   131 134 135  // mono5
        orange  187 120  90
    }
}
